              "storesCredentials": false,
              "storesInventory": false,
              "threats": [
                {
                  "id": "ca55aaae-faaf-4dad-a6c6-2aab6ec370cd",
                  "title": "Sensitive Data Exposure via SQL Injection",
                  "status": "Mitigated",
                  "severity": "Low",
                  "type": "Information disclosure",
                  "description": "An attacker entered ' OR 1=1 -- into the username and password fields of the login form. The application concatenated this input directly into a SQL query, causing the database to return all user records. The attacker was able to extract usernames and hashed passwords from the database response.",
                  "mitigation": "The development team replaced all dynamic SQL queries with parameterized queries (prepared statements), ensuring user input is no longer interpreted as executable SQL. They also implemented server-side input validation to reject suspicious patterns. They restricted the database account used by the application to read-only access for authentication queries, preventing broader data exposure.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 1,
                  "score": ""
                },
                {
                  "id": "e943cf25-bc86-4167-85d4-e0c3f630978f",
                  "title": "Inefficient Queries Caused Database Performance Degradation",
                  "status": "Mitigated",
                  "severity": "Low",
                  "type": "Denial of service",
                  "description": "A newly deployed application feature executed several unoptimized SQL queries that performed full table scans and large multi-table joins without proper indexing. As usage increased, these queries consumed excessive CPU and memory resources, causing the database server to slow significantly and eventually preventing legitimate users from completing transactions.",
                  "mitigation": "The development team optimized the problematic queries by adding indexes to frequently accessed columns and restructuring queries to eliminate unnecessary joins and full table scans. They also implemented query performance monitoring to identify slow queries in real time and configured query execution time limits to prevent any single query from consuming excessive system resources.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": ""
                },
                {
                  "id": "3bc2668d-62f2-4949-ae48-027e6a02d3f6",
                  "title": "Compromised Admin Account Used to Alter Salary Records",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "An attacker used stolen administrator credentials to log into the database and executed an UPDATE statement that increased their own salary in the employee table. The change went initially unnoticed because there was no alert tied to sensitive data modifications.",
                  "mitigation": "The organization has identified the need to enforce multi-factor authentication (MFA) for administrative accounts to prevent unauthorized access using stolen credentials. They also plan to implement role-based access control (RBAC) to limit administrative privileges and enable audit logging with alerting to detect and respond to unauthorized data changes.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 4,
                  "score": ""
                }
              ],
              "threatFrequency": {
                "tampering": 2,
                "repudiation": 0,
                "informationDisclosure": 2,
                "denialOfService": 1
              }
            }
